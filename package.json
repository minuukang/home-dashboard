{
  "name": "home-dashboard",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22.12 <23",
    "yarn": ">=1.22.22 <2"
  },
  "packageManager": "yarn@1.22.22",
  "resolutions": {
    "jws": "4.0.1",
    "qs": "6.15.3"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "apiserve": "nodemon ./api/server.js --watch ./api --ext js,json",
    "start": "node ./api/server.js",
    "build-serve": "yarn build && concurrently --kill-others-on-fail \"yarn apiserve\" \"wait-on tcp:3001 && yarn preview\""
  },
  "main": "index.js",
  "author": "Minwoo Kang",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.20.1",
    "@vitejs/plugin-basic-ssl": "^2.1.0",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "typescript": "^5.9.3",
    "vite": "^8.1.5",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "googleapis": "^173.0.0",
    "lit": "^3.3.3",
    "node-cache": "^5.1.2",
    "twemoji": "^14.0.2"
  }
}
